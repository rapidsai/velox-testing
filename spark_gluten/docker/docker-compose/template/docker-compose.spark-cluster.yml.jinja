#
# Jinja template for a multi-executor Spark Standalone cluster with
# Spark Connect.  Rendered by render_docker_compose_template.py.
#
# Template variables (supplied by the renderer):
#   workers      – list of worker IDs (e.g. [0, 1, 2])
#   num_workers  – length of `workers`
#   gpu          – bool; true for GPU images (adds NVIDIA device reservations)
#   static_jar   – bool; true when using a host-mounted Gluten JAR

x-spark-executor: &executor_base
  image: ${DOCKER_IMAGE}
  labels:
    com.nvidia.spark-connect.user: ${SPARK_CONNECT_USER}
{% if gpu %}
  cap_add:
    - SYS_ADMIN
  env_file:
    - ${SPARK_GPU_ENV_FILE}
  deploy:
    resources:
      reservations:
        devices:
          - driver: nvidia
            count: all
            capabilities: [gpu]
{% endif %}
  depends_on:
    - spark-master
  volumes:
    - ${WORKSPACE_ROOT}:${WORKSPACE_ROOT}
    - ${SPARK_DATA_DIR}:${SPARK_DATA_DIR}
  working_dir: ${WORKSPACE_ROOT}/velox-testing/spark_gluten/scripts
  command: >-
    bash -c "$$SPARK_HOME/bin/spark-class org.apache.spark.deploy.worker.Worker
    spark://spark-master:7077
    --host $$(cat /etc/hostname)
    --cores $${SPARK_WORKER_CORES:-4}
    --memory $${SPARK_WORKER_MEMORY:-48g}"

services:
  spark-master:
    image: ${DOCKER_IMAGE}
    labels:
      com.nvidia.spark-connect.user: ${SPARK_CONNECT_USER}
    container_name: spark-master
    hostname: spark-master
    ports:
      - "${MASTER_WEB_PORT:-8080}:8080"
      - "7077:7077"
    volumes:
      - ${WORKSPACE_ROOT}:${WORKSPACE_ROOT}
      - ${SPARK_DATA_DIR}:${SPARK_DATA_DIR}
    working_dir: ${WORKSPACE_ROOT}/velox-testing/spark_gluten/scripts
    command: >-
      bash -c "$$SPARK_HOME/bin/spark-class org.apache.spark.deploy.master.Master
      --host spark-master --port 7077 --webui-port 8080"

{% for worker_id in workers %}
  spark-executor-{{ worker_id }}:
    <<: *executor_base
    container_name: spark-executor-{{ worker_id }}
    hostname: spark-executor-{{ worker_id }}
{% if gpu %}
    environment:
      CUDA_VISIBLE_DEVICES: "{{ worker_id }}"
{% endif %}
{% endfor %}

  spark-connect:
    image: ${DOCKER_IMAGE}
    labels:
      com.nvidia.spark-connect.user: ${SPARK_CONNECT_USER}
    hostname: spark-connect
{% if gpu %}
    cap_add:
      - SYS_ADMIN
    env_file:
      - ${SPARK_GPU_ENV_FILE}
    deploy:
      resources:
        reservations:
          devices:
            - driver: nvidia
              count: all
              capabilities: [gpu]
{% endif %}
    depends_on:
      - spark-master
    ports:
      - "${CONNECT_PORT:-15002}:${CONNECT_PORT:-15002}"
      - "${UI_PORT:-4040}:${UI_PORT:-4040}"
    volumes:
      - ${WORKSPACE_ROOT}:${WORKSPACE_ROOT}
      - ${SPARK_DATA_DIR}:${SPARK_DATA_DIR}
{% if static_jar %}
      - ${GLUTEN_JAR_DIR}:/opt/gluten/jars:ro
{% endif %}
    working_dir: ${WORKSPACE_ROOT}/velox-testing/spark_gluten/scripts
    environment:
      SPARK_MASTER_URL: "spark://spark-master:7077"
    command: bash launch_spark_connect_server.sh ${CONNECT_PORT:-15002} ${UI_PORT:-4040} ${SPARK_CONFIG_PATH:-}
