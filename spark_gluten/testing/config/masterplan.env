# Environment variables for master plan benchmarks.
# Use with --env-file flag.

# The master plan JAR is built for Spark 3.4.
PYSPARK_VERSION=3.4.4

# Java 17 required by the master plan JAR.
JAVA_HOME=/usr/lib/jvm/java-17
