# GPU environment variables for Gluten benchmarks.
# Use with --env-file to set these in the container environment.

# ---------------------------------------------------------------------------
# cuDF pinned (page-locked) host memory pool
# ---------------------------------------------------------------------------
# Pinned memory enables fast asynchronous DMA transfers between host and
# device over PCIe / NVLink. Pre-allocating a pool avoids the overhead of
# pinning and unpinning memory on every transfer.

# Initial size of the pinned host memory pool: 20 GiB (21474836480 bytes).
# This memory is reserved at startup for host to device data transfers.
LIBCUDF_PINNED_POOL_SIZE=21474836480

# Maximum size the pinned pool can grow to: 40 GiB (42949672960 bytes).
# The pool starts at PINNED_POOL_SIZE and grows on demand up to this limit.
LIBCUDF_PINNED_POOL_MAX_SIZE=42949672960

# ---------------------------------------------------------------------------
# Pinned memory allocation threshold
# ---------------------------------------------------------------------------

# Host memory allocations smaller than or equal to this threshold (1 TiB =
# 1099511627776 bytes) are served from the pinned pool instead of using
# regular pageable malloc.  Setting this to a very large value effectively
# routes all host allocations through the pinned pool, maximising PCIe
# transfer bandwidth at the cost of higher pinned memory usage.
LIBCUDF_ALLOCATE_HOST_AS_PINNED_THRESHOLD=1099511627776
