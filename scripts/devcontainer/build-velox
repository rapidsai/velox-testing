#!/bin/bash
# Build velox with cuDF support
# Usage: build-velox [--release|--debug] [-j N] [--cuda-arch ARCH] [-D<VAR>=<VALUE>]...

set -euo pipefail

# Defaults
BUILD_TYPE="${BUILD_TYPE:-release}"
NUM_THREADS="${NUM_THREADS:-$(nproc --all --ignore=1)}"
BUILD_BASE_DIR="${BUILD_BASE_DIR:-/opt/velox-build}"
CUDAARCHS="${CUDAARCHS:-}"

usage() {
    cat <<EOF
Usage: build-velox [OPTIONS] [-D<VAR>=<VALUE>]...

Build velox with cuDF support.

Any -D flags are passed through to CMake via configure-velox, e.g.:
  build-velox -DVELOX_ENABLE_BENCHMARKS=ON

Options:
  --release         Build in release mode (default)
  --debug           Build in debug mode
  -j, --jobs N      Number of parallel jobs (default: nproc - 1)
  --cuda-arch ARCH  CUDA compute capability (default: auto-detect or 75)
  -h, --help        Show this help message

Environment variables:
  BUILD_TYPE        release or debug
  NUM_THREADS       Number of parallel jobs
  CUDAARCHS         CUDA compute capability
  BUILD_BASE_DIR    Base directory for build output (default: /opt/velox-build)
EOF
}

# Parse arguments — collect -D flags for CMake passthrough
CMAKE_PASSTHROUGH=()
while [[ $# -gt 0 ]]; do
    case "$1" in
        --release) BUILD_TYPE="release"; shift ;;
        --debug) BUILD_TYPE="debug"; shift ;;
        -j|--jobs) NUM_THREADS="$2"; shift 2 ;;
        -j*) NUM_THREADS="${1#-j}"; shift ;;
        --cuda-arch) CUDAARCHS="$2"; shift 2 ;;
        -h|--help) usage; exit 0 ;;
        -D*) CMAKE_PASSTHROUGH+=("$1"); shift ;;
        *) echo "Unknown option: $1"; usage; exit 1 ;;
    esac
done

[[ "${NUM_THREADS}" == "0" ]] && NUM_THREADS="$(ulimit -Hn)"

VELOX_DIR="${HOME}/velox"
if [[ ! -d "${VELOX_DIR}" ]]; then
    echo "Error: velox repository not found at ${VELOX_DIR}"
    echo "Please ensure velox is mounted as a sibling directory."
    exit 1
fi

# Run configuration — forward -D flags to configure-velox
CONFIGURE_ARGS=("--${BUILD_TYPE}")
if [[ -n "${CUDAARCHS}" ]]; then
    CONFIGURE_ARGS+=("--cuda-arch" "${CUDAARCHS}")
fi
CONFIGURE_ARGS+=("${CMAKE_PASSTHROUGH[@]+"${CMAKE_PASSTHROUGH[@]}"}")
BUILD_BASE_DIR="${BUILD_BASE_DIR}" configure-velox "${CONFIGURE_ARGS[@]}"

# Build
cd "${VELOX_DIR}"

echo -e "\033[1;36mBuilding Velox\033[0m"
echo "Threads:  ${NUM_THREADS}"
echo ""

BUILD_START=${SECONDS}
make build BUILD_DIR="${BUILD_TYPE}" BUILD_BASE_DIR="${BUILD_BASE_DIR}" \
    NUM_THREADS="${NUM_THREADS}"

ELAPSED=$(( SECONDS - BUILD_START ))
echo ""
echo -e "\033[1;32mVelox build time:\033[0m $(( ELAPSED / 3600 ))h $(( (ELAPSED % 3600) / 60 ))m $(( ELAPSED % 60 ))s"
echo "Binaries in: ${BUILD_BASE_DIR}/${BUILD_TYPE}"
