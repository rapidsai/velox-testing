# ==============================================================================
# cluster_config.env — Cluster-specific Presto benchmark configuration
# ==============================================================================
# Copy this file to ~/.cluster_config.env (or set CLUSTER_CONFIG to any path).
# Edit all placeholder values for your cluster before running any scripts.
#
# Variables are split into CLUSTER_GPU_* and CLUSTER_CPU_* sections to support
# clusters where different partitions have different hardware topologies (e.g.,
# GPU nodes and CPU-only nodes on the same cluster). The scripts resolve the
# correct set automatically based on the --cpu flag (or its absence).
#
# All variables use the := pattern in scripts, so you can also export any of
# these in your shell before running a launcher to override on a per-run basis.
# ==============================================================================

# --- Shared (same regardless of partition) ---

# Default variant for launchers that accept --cpu / --gpu (launch-run.sh,
# run-interactive.sh).  Set to "cpu" on CPU-only clusters so you don't have
# to pass --cpu on every command.  Leave unset/commented for the built-in
# "gpu" default.  Does not affect launch-gen-data.sh, launch-analyze-tables.sh,
# or pull_ghcr_image.sh — those are always CPU-only.
# CLUSTER_DEFAULT_VARIANT=cpu


# Root of the TPC-H parquet data tree. Must be the *parent* of tpch-rs-<SF>/ dirs.
DATA=/path/to/tpch/data

# Directory containing .sqsh container images.
IMAGE_DIR=/path/to/images

# Root for shared pre-analyzed Hive metastore snapshots (shared across users).
# Unset (comment out) to disable metastore sharing and always run ANALYZE locally.
HIVE_METASTORE_SHARED_ROOT=/path/to/shared/hive_metadata

# Version tag for shared metastore snapshots. Bump when the worker image or
# parquet encoding changes so stale snapshots don't leak into new runs.
# Unset to disable sharing entirely.
HIVE_METASTORE_VERSION=<metastore-version-tag>

# SSH jump host printed as a port-forward hint after job submission.
# Unset (comment out) to suppress the hint.
# CLUSTER_SSH_TUNNEL_HOST=<login-node-or-jump-host>

# Space-separated list of path prefixes that exist only on compute nodes
# (not on the login/host node). Host-side preflight checks against paths
# under these prefixes are skipped; the matching checks inside the .slurm
# scripts (which run on compute nodes) still catch real failures.
# Example for clusters where /scratch is compute-only:
#   CLUSTER_COMPUTE_ONLY_PATHS=/scratch
# Leave empty/commented on clusters where all paths are accessible from the
# login node.
# CLUSTER_COMPUTE_ONLY_PATHS=


# ==============================================================================
# GPU partition
# ==============================================================================

# Slurm partition name. Leave empty/commented to use the cluster default.
CLUSTER_GPU_PARTITION=<gpu-partition-name>

# Slurm account/project code. Leave empty/commented if not required.
# CLUSTER_GPU_ACCOUNT=<gpu-slurm-account>

# Physical CPU cores per node (used for --cpus-per-task).
CLUSTER_GPU_CPUS_PER_TASK=<cores-per-node>

# Number of GPU workers launched per node.
CLUSTER_GPU_NUM_WORKERS_PER_NODE=<gpus-per-node>

# Wall-clock time limits for benchmark and analyze-tables jobs.
CLUSTER_GPU_TIME_BENCHMARK=<HH:MM:SS>
CLUSTER_GPU_TIME_ANALYZE=<HH:MM:SS>

# Presto HTTP port.
CLUSTER_GPU_DEFAULT_PORT=<presto-http-port>

# UCX network device for inter-node communication.
# Leave empty/commented to let UCX auto-select (appropriate for most CPU nodes).
CLUSTER_GPU_UCX_NET_DEVICES=<network-device-name>

# NUMA binding: 1 = bind each worker to its NUMA domain, 0 = no binding.
CLUSTER_GPU_USE_NUMA=1

# Number of GPUs per NUMA domain. Used in the formula: numa_node = gpu_id / N.
# Example: 2 for a node with 4 GPUs across 2 NUMA domains.
CLUSTER_GPU_NUMA_GPUS_PER_NODE=<gpus-per-numa-node>

# Default container image names (without the .sqsh extension).
# Override per-run with -c / -w flags on the launcher.
CLUSTER_GPU_DEFAULT_COORD_IMAGE=<coordinator-image-name>
CLUSTER_GPU_DEFAULT_WORKER_IMAGE=<gpu-worker-image-name>

# Host-side driver library paths to bind-mount into GPU worker containers.
# Both HOST and CONTAINER must be set, or leave both empty to skip the mount.
CLUSTER_GPU_LIBCUDA_HOST_PATH=<host-path-to-libcuda.so>
CLUSTER_GPU_LIBCUDA_CONTAINER_PATH=<container-compat-path-for-libcuda.so>
CLUSTER_GPU_LIBNVIDIA_ML_HOST_PATH=<host-path-to-libnvidia-ml.so>
CLUSTER_GPU_LIBNVIDIA_ML_CONTAINER_PATH=<container-path-for-libnvidia-ml.so>

# Extra comma-separated enroot mounts appended to --container-mounts for GPU jobs.
# Example: CLUSTER_GPU_EXTRA_MOUNTS=/scratch:/scratch
# Leave empty if no extra mounts are needed beyond those the scripts add explicitly.
CLUSTER_GPU_EXTRA_MOUNTS=


# ==============================================================================
# CPU partition
# ==============================================================================

# Slurm partition name. Leave empty/commented to use the cluster default.
CLUSTER_CPU_PARTITION=<cpu-partition-name>

# Slurm account/project code. Leave empty/commented if not required.
# CLUSTER_CPU_ACCOUNT=<cpu-slurm-account>

# Physical CPU cores per node.
CLUSTER_CPU_CPUS_PER_TASK=<cores-per-node>

# Number of Presto workers launched per node (typically 1 for CPU benchmarks).
CLUSTER_CPU_NUM_WORKERS_PER_NODE=<workers-per-node>

# Wall-clock time limits.
CLUSTER_CPU_TIME_BENCHMARK=<HH:MM:SS>
CLUSTER_CPU_TIME_ANALYZE=<HH:MM:SS>

# Presto HTTP port.
CLUSTER_CPU_DEFAULT_PORT=<presto-http-port>

# UCX network device. Leave empty/commented to let UCX auto-select.
# CLUSTER_CPU_UCX_NET_DEVICES=<network-device-name>

# NUMA binding: typically 0 for CPU-only nodes.
CLUSTER_CPU_USE_NUMA=0

# Default container image names.
CLUSTER_CPU_DEFAULT_COORD_IMAGE=<coordinator-image-name>
CLUSTER_CPU_DEFAULT_WORKER_IMAGE=<cpu-worker-image-name>

# Extra comma-separated enroot mounts for CPU jobs.
# Leave empty if no extra mounts are needed.
CLUSTER_CPU_EXTRA_MOUNTS=
