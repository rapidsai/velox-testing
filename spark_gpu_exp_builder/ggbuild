# Unified CLI for the Gluten GPU experimental builder.
#
# Subcommands:
#   build           Main command to build prebuild images or runtime libs or images
#   check-deploy    Validate deploy artifacts (bundle JAR + shared libraries)
#   clean           Clean build caches for Gluten and/or Velox
#   config          Generate a configuration file template
#   extract-libs    Extract deploy libraries from a runtime Docker image

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/scripts" && pwd)"
VERSION="0.1.0"

usage() {
  cat <<EOF
Usage: $(basename "$0") <command> [options]

Gluten GPU Builder CLI — build, validate, and manage Gluten+Velox GPU deployments.

Commands:
  build           Main command to build prebuild images or runtime libs or images
  check-deploy    Validate deploy artifacts (bundle JAR + shared libraries)
  clean           Clean build caches for Gluten and/or Velox
  config          Generate a configuration file template
  extract-libs    Extract deploy libraries from a runtime Docker image

Options:
  -h, --help      Show this help
  --version       Show version

Run '$(basename "$0") <command> --help' for command-specific help.
EOF
}

if [ $# -eq 0 ]; then
  usage
  exit 0
fi

COMMAND="$1"
shift

case "$COMMAND" in
  build)
    export GGBUILD_CMD="ggbuild build"
    exec bash "${SCRIPT_DIR}/docker-build.sh" "$@"
    ;;
  check-deploy)
    export GGBUILD_CMD="ggbuild check-deploy"
    exec bash "${SCRIPT_DIR}/check-deploy.sh" "$@"
    ;;
  clean)
    export GGBUILD_CMD="ggbuild clean"
    exec bash "${SCRIPT_DIR}/clean.sh" "$@"
    ;;
  config)
    export GGBUILD_CMD="ggbuild config"
    exec bash "${SCRIPT_DIR}/config.sh" "$@"
    ;;
  extract-libs)
    export GGBUILD_CMD="ggbuild extract-libs"
    exec bash "${SCRIPT_DIR}/extract-libs.sh" "$@"
    ;;
  -h|--help)
    usage
    exit 0
    ;;
  --version)
    echo "ggbuild ${VERSION}"
    exit 0
    ;;
  *)
    echo "Unknown command: $COMMAND" >&2
    echo "" >&2
    usage >&2
    exit 1
    ;;
esac
